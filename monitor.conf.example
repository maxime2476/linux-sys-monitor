# ==========================================================
# Configuration de linux-sys-monitor
# ==========================================================

# Nom du fichier journal (ex: system_health.log ou system_health.json)
LOG_FILE="system_health.log"

# Seuil d'alerte critique pour l'espace disque (en pourcentage)
DISK_THRESHOLD=80

# Fréquence de vérification en secondes
CHECK_INTERVAL=60

# Format de sortie : "text" ou "json"
OUTPUT_FORMAT="json"

# Seuil d'alerte critique pour les tentatives SSH échouées
SSH_ALERT_THRESHOLD=5

# URL du Webhook (Discord/Slack). Laissez vide pour désactiver les alertes réseaux.
WEBHOOK_URL="VOTRE_LIEN_DISCORD_ICI"

# Service critique à surveiller et redémarrer en cas de crash
CRITICAL_SERVICE="nom_du_service_ici"

# Température critique du CPU en degrés Celsius
TEMP_THRESHOLD=75

# Surveillance Réseau (Ping)
PING_TARGET="1.1.1.1"
# Seuil d'alerte pour la perte de paquets (en pourcentage)
MAX_PACKET_LOSS=20

# Serveur d'exportation Web (Mode Pull pour Prometheus)
ENABLE_WEB_SERVER="true"
WEB_PORT="8080"

# Fichiers critiques à surveiller (File Integrity Monitoring)
FIM_TARGETS="/etc/passwd /etc/ssh/sshd_config"
