# ==========================================================
# linux-sys-monitor configuration
# ==========================================================

# Log filename
LOG_FILE="system_health.log"

# Disk usage alert threshold (percent)
DISK_THRESHOLD=80

# Check interval in seconds
CHECK_INTERVAL=60

# Output format: "text" or "json"
OUTPUT_FORMAT="json"

# Failed SSH login alert threshold
SSH_ALERT_THRESHOLD=5

# Webhook URL (Discord/Slack). Leave empty to disable notifications.
WEBHOOK_URL=""

# Service to monitor and auto-restart on crash (systemd only, leave empty in Docker)
CRITICAL_SERVICE=""

# CPU temperature alert threshold (Celsius)
TEMP_THRESHOLD=75

# Network check target (ping)
PING_TARGET="1.1.1.1"
# Packet loss alert threshold (percent)
MAX_PACKET_LOSS=20

# Web export server (pull mode for Prometheus)
ENABLE_WEB_SERVER="true"
WEB_PORT="8080"

# Files to monitor for integrity changes (space-separated)
FIM_TARGETS="/etc/passwd /etc/ssh/sshd_config"

# Domains to check for SSL certificate expiry (space-separated)
SSL_DOMAINS="google.com github.com"
# Alert threshold in days remaining
SSL_DAYS_THRESHOLD=15

# Monitor stopped/dead Docker containers (true/false)
CHECK_DOCKER="true"
