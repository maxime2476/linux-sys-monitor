{
  "title": "Linux System Monitor Dashboard",
  "panels": [
    {
      "title": "RAM Usage",
      "type": "gauge",
      "targets": [{ "target": "metrics.hardware.ram_used_mb" }]
    },
    {
      "title": "CPU Temperature",
      "type": "graph",
      "targets": [{ "target": "metrics.hardware.cpu_temp_c" }]
    },
    {
      "title": "FIM Alerts",
      "type": "stat",
      "targets": [{ "target": "alerts.file_integrity_compromised" }]
    }
  ]
}
